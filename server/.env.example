# Required: your TransLink GTFS-RT API key (stays server-side, never in the app)
TRANSLINK_API_KEY=your_key_here

# Optional: shared secret. If set, the app must send it as the `x-app-token`
# header (EXPO_PUBLIC_APP_TOKEN in the app). Blocks random abuse of your proxy.
# APP_TOKEN=some-long-random-string

# Optional cache windows (ms). Larger = fewer upstream calls = safer under the cap.
# TTL_TRIPS_MS=30000
# TTL_POS_MS=30000
# TTL_ALERTS_MS=120000

# Port (most hosts set this automatically)
# PORT=8080
